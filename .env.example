# Copy to .env.local (never commit secrets)

# --- AI (client-exposed via Vite define) ---
GEMINI_API_KEY=

# --- Federal grants (optional enhancements; Grants.gov works with NO key) ---
# Free: https://simpler.grants.gov → Developer → Manage API Keys
SIMPLER_GRANTS_API_KEY=

# --- Federal contracts: open solicitations ---
# Free personal key: https://sam.gov → Account Details → API Key
# Docs: https://open.gsa.gov/api/get-opportunities-public-api/
SAM_API_KEY=

# --- Optional paid / aggregator APIs ---
# Grants-USA on RapidAPI
GRANTS_USA_RAPIDAPI_KEY=
# GRANTS_USA_RAPIDAPI_HOST=grants-usa.p.rapidapi.com
# GRANTS_USA_PATH=/search?query=...

# OpenGrants https://app.opengrants.io/
OPENGRANTS_API_KEY=

# Tango / MakeGov https://www.makegov.com/
TANGO_API_KEY=
# MAKEGOV_API_KEY=

# --- Always free (no keys) ---
# Grants.gov search2  → proxied /api/grants.gov
# USASpending.gov     → proxied /api/usaspending
# SBIR.gov            → public API when available
